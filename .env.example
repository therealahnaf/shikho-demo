# Git deployment source. Use owner/repository or a complete HTTPS GitHub URL.
GITHUB_REPOSITORY=your-github-user/your-repository
GITHUB_BRANCH=main
DEPLOY_DIRECTORY=/opt/studycircle

# Docker Compose
COMPOSE_PROJECT_NAME=studycircle
POSTGRES_DB=studycircle_demo
POSTGRES_USER=studycircle
POSTGRES_PASSWORD='replace-with-a-long-random-password'
BACKEND_LOCAL_PORT=8000
FRONTEND_LOCAL_PORT=8080

# Public HTTPS URLs configured as Cloudflare Tunnel public hostnames.
# Do not include a trailing slash.
FRONTEND_PUBLIC_URL=https://studycircle.example.com
BACKEND_PUBLIC_URL=https://studycircle-api.example.com

# Tokens from two remotely-managed Cloudflare tunnels.
CLOUDFLARE_FRONTEND_TUNNEL_TOKEN=replace-with-frontend-tunnel-token
CLOUDFLARE_BACKEND_TUNNEL_TOKEN=replace-with-backend-tunnel-token

# Run the idempotent seed command on every deployment.
SEED_DATA=true
