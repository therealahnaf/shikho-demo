# Fine-grained GitHub PAT with read access to therealahnaf/shikho-demo.
GITHUB_PAT=replace-with-github-pat

# Use URL-safe credentials. The deploy script derives PostgreSQL initialization
# values from this connection string.
DATABASE_URL=postgresql+psycopg://studycircle:replace-with-url-safe-password@db:5432/studycircle_demo

FRONTEND_PUBLIC_URL=https://shikho-demo.codeastrix.com
BACKEND_PUBLIC_URL=https://shikho-demo-api.codeastrix.com

CLOUDFLARE_FRONTEND_TUNNEL_TOKEN=replace-with-frontend-tunnel-token
CLOUDFLARE_BACKEND_TUNNEL_TOKEN=replace-with-backend-tunnel-token
